# Mantle Agent Pulse — Environment Variables
# Copy this file to .env and fill in values as needed.

# REQUIRED ONLY for --register-agent (optional feature).
# Private key for the wallet that will register this agent on-chain.
# NEVER commit a real private key. Fund the wallet with MNT for gas.
# AGENT_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# Optional: custom agent name and metadata URI for on-chain registration.
# AGENT_NAME=mantle-agent-pulse
# AGENT_METADATA_URI=https://github.com/yourusername/mantle-agent-pulse
